{
  "name": "npm-outdated-check",
  "version": "1.0.0",
  "description": "CI-friendly dependency version threshold checker with configurable version drift limits and meaningful exit codes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "npm-outdated-check": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --test test/test.mjs",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "npm",
    "outdated",
    "dependencies",
    "ci",
    "version",
    "threshold",
    "semver",
    "check",
    "dependency",
    "management"
  ],
  "author": "Sulthon",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/npm-outdated-check.git"
  },
  "bugs": {
    "url": "https://github.com/sulthonzh/npm-outdated-check/issues"
  },
  "homepage": "https://github.com/sulthonzh/npm-outdated-check#readme"
}
